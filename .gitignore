# Gradle
.gradle/
# Anchor to the repo root so this only ignores Gradle's output dir — an unanchored `build/` also
# matched the `engine/build/` SOURCE package (it was silently untracked until 2026-06-04).
/build/
!gradle/wrapper/gradle-wrapper.jar

# IDE
.idea/
*.iml
.vscode/
.project
.classpath
.settings/

# OS
.DS_Store

# Logs
*.log
logs/

# Env / secrets
.env
.env.local
.env.dev
.env.*.local
*.pem
*.key

# Node / frontend (Phase 13)
frontend/node_modules/
frontend/dist/
frontend/.vite/

# Helm packaging
helm/*.tgz

# Real report drops are local-only — never commit report XML (may contain real PII).
# Anonymized samples for tests live under src/test/resources/samples/. The goAML XSDs in assets/ stay tracked.
assets/*.xml

# Local-only dev helpers (dev keys, smoke scripts) — never commit.
dev-local/
