# Copy to deploy/.env and fill in. Consumed by deploy/docker-compose.yml.
# deploy/.env is git-ignored (never commit real secrets).

# --- Database (the compose 'db' service is created with these) ---
POSTGRES_DB=goaml
POSTGRES_USER=goaml
POSTGRES_PASSWORD=goaml

# --- JWT signing key (HS256) ---
# REQUIRED. Must be >= 32 bytes or the app will not issue valid tokens.
# Generate: openssl rand -base64 48
GOAML_JWT_SECRET=change-me-to-a-32-byte-minimum-random-secret

# --- Auth on-ramps: native | federated | both ---
GOAML_AUTH_MODE=both

# --- Host ports (published on the server) ---
# UI + API is reachable at http://<host>:${GOAML_HTTP_PORT}
GOAML_HTTP_PORT=8091
# These two are only for host-side debugging (psql/redis-cli); the app uses the internal network.
POSTGRES_HOST_PORT=5434
REDIS_HOST_PORT=6381

# --- Background FIU status poller (fine on for a single instance) ---
GOAML_SCHEDULER_ENABLED=true

# --- Dev seed ---------------------------------------------------------------------------------------
# true  -> seeds a demo tenant + ready login users so you can sign in immediately (password Passw0rd!):
#            SUPER_ADMIN  companyId PLATFORM  superadmin@goaml.local
#            TENANT_ADMIN companyId demo      admin@demo.local
#            MLRO         companyId demo      mlro@demo.local
#            ANALYST      companyId demo      analyst@demo.local
# false -> no seed; provision your own tenant via the SUPER_ADMIN / provisioning API.
# NOTE: leave this OFF for a real, internet-exposed production deployment.
GOAML_DEV_SEED=true

# --- AWS (optional) ---------------------------------------------------------------------------------
# Only used for LIVE FIU submission (Secrets Manager holds per-tenant B2B creds) and S3 attachments,
# both gated off by default. Leave GOAML_AWS_ENDPOINT blank for real AWS (uses IRSA/default chain);
# set it to a LocalStack URL (e.g. http://localstack:4566) to exercise those paths locally.
GOAML_AWS_ENDPOINT=
GOAML_AWS_REGION=me-central-1
